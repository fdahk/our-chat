# our-chat 部署/编排环境变量(docker compose 单一配置源)。
# 复制为 docker/.env(已被 .gitignore 忽略)按需覆盖。
#
# 两种用途:
#   1) compose 内 ${VAR} 替换(端口/镜像等)——在 docker/ 下执行自动加载本文件;
#   2) env_file 整体注入容器(server/gateway 进程读 process.env / os.Getenv)。
#
# 宿主机直跑(npm run dev / go run)不读本文件,见 server/.env.example、web/.env.example。

# ── 对外入口端口(nginx 边缘入口)──
WEB_PORT=8080

# ── Postgres ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=our_chat
POSTGRES_PORT=5432

# ── Redis ──
REDIS_PORT=6379

# ── 容器内连接串(docker 网络主机名,勿改成 localhost)──
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/our_chat
REDIS_URL=redis://redis:6379

# ── 鉴权(server 与 gateway 共享同一密钥)── 生产必须改成足够长随机串(openssl rand -hex 32)
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d
GATEWAY_INTERNAL_TOKEN=dev-internal-token

# ── 前端 origin / OAuth(需与实际访问地址一致)──
CLIENT_ORIGINS=http://localhost:8080
OAUTH_ISSUER_BASE_URL=http://localhost:8080
OAUTH_WEB_REDIRECT_URI=http://localhost:8080/oauth/callback

# ── OAuth IdP 签发参数 ──
OAUTH_ACTIVE_KID=dev
OAUTH_RETIRED_KIDS=
# 私钥文件路径(容器内,需与 OAUTH_ACTIVE_KID 对应;由 ../server/keys 只读挂载)
OAUTH_PRIVATE_KEY_FILE=/app/keys/oauth-private-dev.pem
OAUTH_AT_TTL_SEC=900
OAUTH_RT_TTL_SEC=2592000
OAUTH_ID_TTL_SEC=900
OAUTH_CODE_TTL_SEC=60

# ── 文件存储(S3 兼容对象存储)──
#   dev(docker-compose.dev.yml 的 MinIO):下方默认值即可,同时作为 MinIO root 账号
#   prod:换成腾讯云 COS 的 S3 兼容 endpoint 与 SecretId/SecretKey
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=our-chat
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/our-chat

# ── 仅 docker-compose.dev.yml(MinIO 端口/控制台)──
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
