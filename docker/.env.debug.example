# our-chat 本地开发环境变量(集中一份)。复制为 docker/.env.debug。
#
# 模式:中间件(postgres/redis/minio)跑 docker,业务(server/gateway)跑宿主机。
# 因此这里全是 localhost 地址(经中间件暴露到本机的端口连接)。
# 由两处共享读取:
#   - server :  pnpm dev 经 DOTENV_CONFIG_PATH 指向本文件
#   - gateway:  make gateway 时 source 本文件
# 生产/容器编排请用 docker/.env(容器主机名),两者勿混用。

# ── server ──
PORT=3007
NODE_ENV=development
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://localhost:5173,https://127.0.0.1:5173

# ── 鉴权(server 与 gateway 共享,必须一致)──
# 注:gateway 缺 JWT_SECRET 会 fail-fast,故 dev 必须给一个共享值(勿留空)
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d
GATEWAY_INTERNAL_TOKEN=dev-internal-token

# ── 数据库 / Redis(宿主机经 localhost 连 docker 中间件)──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/our_chat
REDIS_URL=redis://localhost:6379

# ── OAuth IdP ──
OAUTH_ISSUER_BASE_URL=http://localhost:3007
OAUTH_ACTIVE_KID=dev
OAUTH_RETIRED_KIDS=
OAUTH_PRIVATE_KEY_FILE=keys/oauth-private-dev.pem
OAUTH_AT_TTL_SEC=900
OAUTH_RT_TTL_SEC=2592000
OAUTH_ID_TTL_SEC=900
OAUTH_CODE_TTL_SEC=60

# ── 文件存储(dev:本地 MinIO,docker-compose.dev.yml 暴露在 localhost:9000)──
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=our-chat
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/our-chat

# ── gateway(宿主机直跑)──
GATEWAY_ADDR=:8090
UPSTREAM_BASE_URL=http://127.0.0.1:3007
GATEWAY_MAX_CONNS=50000
GATEWAY_SEND_BUFFER=256
GATEWAY_HEARTBEAT_TIMEOUT_SEC=60
