{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "bash scripts/setup-dev.sh",
    "dev": "tsx watch src/server.ts",
    "build": "rm -rf dist && pnpm db:generate && tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docker:mw": "docker compose -f ../docker/docker-compose.dev.yml up -d",
    "docker:pg": "docker compose -f ../docker/docker-compose.dev.yml up -d postgres",
    "docker:build": "docker compose -f ../docker/docker-compose.yml build",
    "docker:up": "docker compose -f ../docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f ../docker/docker-compose.yml down",
    "docker:logs": "docker compose -f ../docker/docker-compose.yml logs -f",
    "docker:logs:server": "docker compose -f ../docker/docker-compose.yml logs -f server",
    "docker:logs:pg": "docker compose -f ../docker/docker-compose.yml logs -f postgres",
    "clean:db": "docker compose -f ../docker/docker-compose.dev.yml down -v",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:reset": "prisma migrate reset",
    "db:baseline": "prisma migrate resolve --applied 0_initial",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/lib-storage": "^3.1073.0",
    "@prisma/client": "^6.19.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^17.4.2",
    "express": "~4.16.1",
    "http-errors": "~1.6.3",
    "ioredis": "^5.11.1",
    "jade": "~1.11.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.2.10",
    "morgan": "~1.9.1",
    "multer": "^2.0.1",
    "sharp": "^0.34.3",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.19.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.10.0+sha512.d615db246fe70f25dcfea6d8d73dee782ce23e2245e3c4f6f888249fb568149318637dca73c2c5c8ef2a4ca0d5657fb9567188bfab47f566d1ee6ce987815c39"
}
