// Prisma schema 是 our-chat server 的唯一数据模型来源。
// 所有 schema 变更必须经 `pnpm db:migrate:dev`(开发)或 `pnpm db:migrate:deploy`(生产)。
// 命名约定:PascalCase model + camelCase field + @map 到 snake_case 列名(与 agent-server 对齐)。
//
// 数据库:PostgreSQL(本次从 MySQL+MongoDB 双库统一过来,见 docs/database/03-PG统一替换MongoDB决策记录.md)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ 用户与社交 ============

model User {
  id        BigInt      @id @default(autoincrement())
  username  String      @unique @db.VarChar(50)
  email     String?     @unique @db.VarChar(100)
  phone     String?     @unique @db.VarChar(20)
  password  String      @db.VarChar(255)
  nickname  String?     @db.VarChar(50)
  avatar    String?     @db.VarChar(255)
  bio       String?     @db.Text
  gender    String?     @db.VarChar(16)
  status    UserStatus? @default(offline)
  lastSeen  DateTime?   @map("last_seen") @db.Timestamptz(0)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedAt DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(0)

  ownedGroups        UserGroup[]
  friendships        Friendship[]       @relation("UserFriendships")
  inboundFriendships Friendship[]       @relation("FriendInboundFriendships")
  groupMemberships   GroupMember[]
  conversations      UserConversation[]
  sentMessageRefs    MessageRef[]       @relation("MessageRefSender")
  sentMessages       Message[]          @relation("MessageSender")

  @@map("users")
}

enum UserStatus {
  online
  offline
  busy
  away
  deleted
}

model UserGroup {
  id          BigInt    @id @default(autoincrement())
  name        String    @db.VarChar(100)
  description String?   @db.Text
  avatar      String?   @db.VarChar(255)
  ownerId     BigInt    @map("owner_id")
  maxMembers  Int       @default(500) @map("max_members")
  groupType   GroupType @default(private) @map("group_type")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(0)

  owner   User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members GroupMember[]

  @@map("user_groups")
}

enum GroupType {
  public
  private
}

model Friendship {
  id        BigInt           @id @default(autoincrement())
  userId    BigInt           @map("user_id")
  friendId  BigInt           @map("friend_id")
  status    FriendshipStatus @default(pending)
  remark    String?          @db.VarChar(64)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedAt DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(0)

  user   User @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendInboundFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId], map: "unique_friendship")
  @@map("friendships")
}

enum FriendshipStatus {
  sent
  pending
  accepted
  blocked
}

model GroupMember {
  id       BigInt     @id @default(autoincrement())
  groupId  BigInt     @map("group_id")
  userId   BigInt     @map("user_id")
  role     MemberRole @default(member)
  nickname String?    @db.VarChar(50)
  joinedAt DateTime   @default(now()) @map("joined_at") @db.Timestamptz(0)

  group UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId], map: "unique_member")
  @@map("group_members")
}

enum MemberRole {
  owner
  admin
  member
}

// ============ 会话与消息 ============

model Conversation {
  id        String   @id @db.VarChar(100)
  convType  ConvType @map("conv_type")
  title     String?  @db.VarChar(100)
  avatar    String?  @db.VarChar(255)
  // 会话内单调发号器。每条消息在同一事务里 UPDATE ... next_seq+1 RETURNING 取号,
  // 保证会话内 seq 连续无洞(gap 检测与范围补拉的前提)。详见 docs 11。
  nextSeq   BigInt   @default(0) @map("next_seq")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(0)

  participants UserConversation[]
  messageRefs  MessageRef[]
  messages     Message[]

  @@map("conversations")
}

enum ConvType {
  single
  group
}

model UserConversation {
  id                BigInt   @id @default(autoincrement())
  userId            BigInt   @map("user_id")
  conversationId    String   @map("conversation_id") @db.VarChar(100)
  lastReadMessageId String?  @map("last_read_message_id") @db.VarChar(50)
  // 两个独立单调游标(INV-5):synced=已收到并落地到的 seq,read=用户已看到的 seq。
  // 未读数 = lastSyncedSeq - lastReadSeq,不再依赖易漂移的 unreadCount 计数器。详见 docs 13。
  lastSyncedSeq     BigInt   @default(0) @map("last_synced_seq")
  lastReadSeq       BigInt   @default(0) @map("last_read_seq")
  unreadCount       Int      @default(0) @map("unread_count")
  isMuted           Boolean  @default(false) @map("is_muted")
  isPinned          Boolean  @default(false) @map("is_pinned")
  isArchived        Boolean  @default(false) @map("is_archived")
  joinedAt          DateTime @default(now()) @map("joined_at") @db.Timestamptz(0)
  lastActivity      DateTime @default(now()) @updatedAt @map("last_activity") @db.Timestamptz(0)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId], map: "unique_user_conversation")
  @@map("user_conversations")
}

// per-device 同步态:同一用户多设备时,每个设备各自追平消息的位点(docs 15 §6,坑3)。
// synced 必须 per-device(否则一端推进了用户级游标,另一端会永久缺消息);
// read 仍留在 UserConversation 保持 per-user(在任一端读都算"这个人读过了")。
model DeviceSyncState {
  userId         BigInt   @map("user_id")
  deviceId       String   @map("device_id") @db.VarChar(64)
  conversationId String   @map("conversation_id") @db.VarChar(100)
  lastSyncedSeq  BigInt   @default(0) @map("last_synced_seq")
  lastHeartbeat  DateTime @default(now()) @updatedAt @map("last_heartbeat") @db.Timestamptz(0)

  @@id([userId, deviceId, conversationId])
  @@map("device_sync_state")
}

// MessageRef:保留作 conversation/sender 维度的轻量索引引用(给 MySQL 时代的兼容查询用)。
// 真实消息体在 Message 表(从 MongoDB 迁移而来)。
model MessageRef {
  id             String   @id @db.VarChar(50)
  conversationId String   @map("conversation_id") @db.VarChar(100)
  senderId       BigInt   @map("sender_id")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(0)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageRefSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("message_refs")
}

// ============ 消息(本次从 MongoDB 迁移到 PG)============

// 消息主体。稳定字段用列,灵活内容(mentions / extra / fileInfo / editHistory)用 JSONB。
// 复合索引 (conversation_id, timestamp DESC) 是核心查询路径,DISTINCT ON 命中此索引可 Index-Only Scan。
model Message {
  id             BigInt   @id @default(autoincrement())
  conversationId String   @map("conversation_id") @db.VarChar(100)
  senderId       BigInt   @map("sender_id")
  // 会话内单调序号(发号器分配),范围查询与 gap 检测的位点。
  seq            BigInt   @default(0)
  // 客户端幂等键(UUIDv4),重发复用同键;配合唯一约束做去重(at-least-once + 幂等)。详见 docs 12。
  clientMsgId    String?  @map("client_msg_id") @db.VarChar(64)
  content        String   @db.Text
  type           String   @default("text") @db.VarChar(32)
  status         String   @default("sent") @db.VarChar(32)
  mentions       Json     @default("[]") @db.JsonB
  isEdited       Boolean  @default(false) @map("is_edited")
  isDeleted      Boolean  @default(false) @map("is_deleted")
  extra          Json     @default("{}") @db.JsonB
  fileInfo       Json     @default("{}") @map("file_info") @db.JsonB
  editHistory    Json     @default("[]") @map("edit_history") @db.JsonB
  timestamp      DateTime @default(now()) @db.Timestamptz(0)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(0)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp(sort: Desc)], map: "idx_messages_conv_ts")
  @@index([senderId, timestamp(sort: Desc)], map: "idx_messages_sender_ts")
  // 范围补拉走该索引做 Index Range Scan(WHERE conv=X AND seq>since ORDER BY seq)。
  @@index([conversationId, seq(sort: Desc)], map: "idx_messages_conv_seq")
  // 去重锚:同一 (会话,发送者,客户端幂等键) 至多入库一次。clientMsgId 为 NULL 时不参与约束。
  @@unique([conversationId, senderId, clientMsgId], map: "uniq_msg_idem")
  @@map("messages")
}

// 会话缓存(MongoDB 时代用于快速查询的反范式表,迁来 PG 仍保留)
model ConversationCache {
  id            String   @id @db.VarChar(100)
  type          String?  @db.VarChar(16)
  title         String?  @db.VarChar(100)
  avatar        String?  @db.VarChar(255)
  participants  Json     @default("[]") @db.JsonB
  lastMessage   Json?    @map("last_message") @db.JsonB
  totalMessages Int      @default(0) @map("total_messages")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(0)

  @@map("conversation_cache")
}

// 用户会话状态(typing 指示 / 最后已读)
model UserConversationState {
  id                BigInt    @id @default(autoincrement())
  userId            String    @map("user_id") @db.VarChar(64)
  conversationId    String    @map("conversation_id") @db.VarChar(100)
  lastReadMessageId String?   @map("last_read_message_id") @db.VarChar(50)
  lastReadTime      DateTime  @default(now()) @map("last_read_time") @db.Timestamptz(0)
  typing            Boolean   @default(false)
  typingAt          DateTime? @map("typing_at") @db.Timestamptz(0)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(0)

  @@unique([userId, conversationId], map: "unique_user_conv_state")
  @@index([userId], map: "idx_user_conv_state_user")
  @@index([conversationId], map: "idx_user_conv_state_conv")
  @@map("user_conversation_states")
}

// 文件信息
model FileInfo {
  id             String   @id @db.VarChar(64)
  originalName   String?  @map("original_name") @db.VarChar(255)
  fileName       String?  @map("file_name") @db.VarChar(255)
  mimeType       String?  @map("mime_type") @db.VarChar(128)
  size           BigInt?
  url            String?  @db.VarChar(512)
  thumbnail      String?  @db.VarChar(512)
  uploaderId     String?  @map("uploader_id") @db.VarChar(64)
  conversationId String?  @map("conversation_id") @db.VarChar(100)
  messageId      String?  @map("message_id") @db.VarChar(64)
  uploadedAt     DateTime @default(now()) @map("uploaded_at") @db.Timestamptz(0)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(0)

  @@index([uploaderId], map: "idx_file_info_uploader")
  @@index([conversationId], map: "idx_file_info_conv")
  @@map("file_info")
}

// ============ OAuth 2.1 / OIDC IdP ============

model OAuthClient {
  clientId           String          @id @map("client_id") @db.VarChar(64)
  clientName         String          @map("client_name") @db.VarChar(128)
  clientType         OAuthClientType @map("client_type")
  clientSecretHash   String?         @map("client_secret_hash") @db.VarChar(255)
  redirectUris       Json            @map("redirect_uris") @db.JsonB
  allowedScopes      Json            @map("allowed_scopes") @db.JsonB
  allowedGrantTypes  Json            @map("allowed_grant_types") @db.JsonB
  tokenLifetimeSec   Int             @default(900) @map("token_lifetime_sec")
  refreshLifetimeSec Int             @default(2592000) @map("refresh_lifetime_sec")
  requirePkce        Boolean         @default(true) @map("require_pkce")
  disabled           Boolean         @default(false)
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(0)
  updatedAt          DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(0)

  @@map("oauth_clients")
}

enum OAuthClientType {
  public
  confidential
}

model OAuthCode {
  code                String                   @id @db.VarChar(64)
  clientId            String                   @map("client_id") @db.VarChar(64)
  userId              BigInt                   @map("user_id")
  redirectUri         String                   @map("redirect_uri") @db.VarChar(512)
  codeChallenge       String                   @map("code_challenge") @db.VarChar(128)
  codeChallengeMethod OAuthCodeChallengeMethod @map("code_challenge_method")
  scope               String                   @db.VarChar(512)
  nonce               String?                  @db.VarChar(255)
  expiresAt           DateTime                 @map("expires_at") @db.Timestamptz(0)
  used                Boolean                  @default(false)
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamptz(0)

  @@index([expiresAt], map: "idx_oauth_codes_expires")
  @@index([userId], map: "idx_oauth_codes_user")
  @@map("oauth_codes")
}

enum OAuthCodeChallengeMethod {
  S256
}

model OAuthRefreshToken {
  jti          String    @id @db.VarChar(64)
  familyId     String    @map("family_id") @db.VarChar(64)
  clientId     String    @map("client_id") @db.VarChar(64)
  userId       BigInt    @map("user_id")
  scope        String    @db.VarChar(512)
  issuedAt     DateTime  @default(now()) @map("issued_at") @db.Timestamptz(0)
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(0)
  revoked      Boolean   @default(false)
  rotatedTo    String?   @map("rotated_to") @db.VarChar(64)
  rotatedAt    DateTime? @map("rotated_at") @db.Timestamptz(0)
  revokeReason String?   @map("revoke_reason") @db.VarChar(64)

  @@index([familyId], map: "idx_oauth_rt_family")
  @@index([userId, revoked, expiresAt], map: "idx_oauth_rt_user_active")
  @@index([expiresAt], map: "idx_oauth_rt_expires")
  @@map("oauth_refresh_tokens")
}
