# our-chat server 配置示例
# 拷贝为 .env 并填入实际值

# ────────────────────────────────────────────────────────
# 服务
# ────────────────────────────────────────────────────────
PORT=3007
NODE_ENV=development

# 允许的前端跨域来源(逗号分隔)
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ────────────────────────────────────────────────────────
# 现有业务 JWT(给 our-chat 自家 API 用,HS256 + cookie)
# ────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ────────────────────────────────────────────────────────
# 数据库(Prisma + PostgreSQL)
# ────────────────────────────────────────────────────────
# 自 2026-06 起本项目改用 PostgreSQL 统一关系层与消息层
# (从 MySQL + MongoDB 双库迁移过来,见 docs/database/03)
# 格式:postgresql://<user>:<password>@<host>:<port>/<database>
# 密码含特殊字符需 URL-encode(@ → %40, # → %23 ...)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/our_chat

# ────────────────────────────────────────────────────────
# OAuth IdP 模块
# ────────────────────────────────────────────────────────

# issuer 必须是公网可达的 base URL,resource server 据此校验 iss claim
OAUTH_ISSUER_BASE_URL=http://localhost:3007

# 当前用于签发新 token 的 kid
OAUTH_ACTIVE_KID=dev

# 仅暴露公钥但不再签新 token 的旧 kid(滚动轮换期使用,逗号分隔)
OAUTH_RETIRED_KIDS=

# 私钥文件路径(单 kid 场景,生产推荐 secret volume 挂载)
OAUTH_PRIVATE_KEY_FILE=keys/oauth-private-dev.pem

# 多 kid 场景下扫描整个目录,文件名约定 oauth-private-<kid>.pem
# OAUTH_KEY_DIR=keys

# token TTL(秒)
OAUTH_AT_TTL_SEC=900
OAUTH_RT_TTL_SEC=2592000
OAUTH_ID_TTL_SEC=900
OAUTH_CODE_TTL_SEC=60
