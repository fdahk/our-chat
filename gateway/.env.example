# our-chat Go 连接网关配置示例。拷贝为 .env 并填入实际值(或直接用环境变量注入)。
# 键名与 Node 后端对齐(JWT_SECRET / REDIS_URL),网关与业务进程共享同一登录密钥与 Redis。

# 网关 WS / metrics / 健康检查监听地址。
GATEWAY_ADDR=:8090

# HS256 校验 our-chat 登录 token 的密钥,必须与 Node 的 JWT_SECRET 完全一致。
JWT_SECRET=

# Redis 连接(presence 注册表 + gw:downlink 下行 pub/sub),与 Node 同一实例。
REDIS_URL=redis://localhost:6379

# Node 业务进程基址,上行透传落库走 <base>/internal/gateway/uplink。
UPSTREAM_BASE_URL=http://127.0.0.1:3007

# 与 Node 内部端点的共享令牌,必须与 server 的 GATEWAY_INTERNAL_TOKEN 一致。
GATEWAY_INTERNAL_TOKEN=dev-internal-token

# 单网关进程的连接数硬上限,超过即拒绝握手(防 fd/内存爆)。
GATEWAY_MAX_CONNS=50000

# 每连接下行发送缓冲的有界容量,满即判定慢消费者并逐出(背压)。
GATEWAY_SEND_BUFFER=256

# 应用层心跳超时(秒),超过未收到 ping/pong 即判连接死并摘除。
GATEWAY_HEARTBEAT_TIMEOUT_SEC=60

# 副本标识,写入 presence:meta,供跨副本定位连接所在网关。缺省 gw-<hostname>。
# REPLICA_ID=gw-1
